# ──────────────────────────────────────────────
# Python
# ──────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg
*.egg-info/
dist/
build/
.eggs/

# ──────────────────────────────────────────────
# Virtual environments
# ──────────────────────────────────────────────
venv/
.venv/
env/
.env/

# ──────────────────────────────────────────────
# Environment / secrets  ← NEVER commit credentials
# ──────────────────────────────────────────────
.env
.env.*
secrets.json

# ──────────────────────────────────────────────
# Database
# ──────────────────────────────────────────────
database/SpaceData.db
database/SpaceData.db-shm
database/SpaceData.db-wal

# ──────────────────────────────────────────────
# Generated / processed data
# ──────────────────────────────────────────────
data/processed/*.parquet
data/processed/*.json
data/raw/spacetrack/*.txt
data/external/*

# ──────────────────────────────────────────────
# Generated reports and logs
# ──────────────────────────────────────────────
reports/
logs/
*.log

# ──────────────────────────────────────────────
# macOS
# ──────────────────────────────────────────────
.DS_Store
.AppleDouble
Thumbs.db

# ──────────────────────────────────────────────
# IDEs
# ──────────────────────────────────────────────
.vs/
.vscode/
.idea/
*.user
*.suo
*.swp
*.swo

# ──────────────────────────────────────────────
# Jupyter
# ──────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ──────────────────────────────────────────────
# Misc
# ──────────────────────────────────────────────
*.tmp
*.bak
# ──────────────────────────────────────────────
# Allow empty folder structures to be committed
# ──────────────────────────────────────────────
!.gitkeep